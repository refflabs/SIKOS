{
  "version": 2,
  "framework": null,
  "buildCommand": "echo 'skip'",
  "outputDirectory": ".",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "regions": ["sin1"]
    }
  },
  "routes": [
    {
      "src": "/(css|js|images|uploads)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
